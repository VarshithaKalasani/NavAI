{
  "manifest_version": 3,
  "name": "NavAI - Accessible Voice Web Navigator",
  "version": "1.0.0",
  "description": "AI-powered voice navigation for visually impaired users. Speak a command, NavAI finds it and reads it back.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "NavAI - Click to start voice navigation",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}